#!/bin/bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
    echo "Usage: $0 <container-name> [command...]" >&2
    exit 1
fi

container_name="$1"
shift

until [ "$(sudo docker inspect -f '{{.State.Running}}' "$container_name" 2>/dev/null || true)" = "true" ]; do
    sleep 1
done

if [ "$#" -eq 0 ]; then
    exec sudo docker exec -it "$container_name" bash
fi

exec sudo docker exec "$container_name" "$@"
